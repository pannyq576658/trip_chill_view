@page
@model trip_chill_view.Pages.CreatePurposeModel
@{
}
<link rel="stylesheet" href="~/css/search-group.css">
<link rel="stylesheet" href="~/css/purpose.css">
<div class="Wrapper-hot-color">
    <div class="container">
        <div class="col-group-title-hot-01">
            <h3>創立宗旨</h3>
            <!--<p>精選近3個月暢銷課程，緊跟潮流!</p>-->
        </div>
        <div>
            <hr>
        </div>

        <!-- 刪除三大支柱和四大承諾後的 HTML -->

        <div class="purpose-container">
            <!-- Hero 區域 -->
            <section class="purpose-hero">
                <div class="hero-content">
                    <h1>我們的創立宗旨</h1>
                    <p class="hero-subtitle">
                        Trip Chill View 的創立源於我們對旅遊的熱情與對服務的執著。
                        我們發現許多旅客在規劃旅程時面臨諸多挑戰——複雜的預訂流程、
                        分散的信息、不透明的定價。我們致力於消除這些障礙，
                        讓每個人都能輕鬆、安心地享受探索世界的樂趣。
                    </p>
                </div>
            </section>

            <!-- 主要內容 -->
            <section class="purpose-content">
                <div class="container">                   
                    <!-- 我們的故事 -->
                    <div class="purpose-section story-section">
                        <h2>我們的故事</h2>
                        <div class="story-content">
                            <div class="story-text">
                                <p>
                                    Trip Chill View 的誕生源於創辦人對世界的探索熱情。
                                    在多次出國旅遊的經歷中，我們發現旅客面臨許多共同的困擾：
                                    如何在眾多選擇中找到最適合的行程？如何確保價格透明公平？
                                    如何在遇到問題時快速得到幫助？
                                </p>
                                <p>
                                    這些問題激發了我們創建 Trip Chill View 的想法——
                                    一個能夠整合所有旅遊服務、提供一站式解決方案的平台。
                                    經過多年的開發、測試和完善，Trip Chill View 終於上線。
                                    今天，我們已為數千名客戶服務，幫助他們規劃和實現夢想旅行。
                                </p>
                            </div>
                           
                        </div>
                    </div>

                   

                   

                    <!-- CTA 按鈕 -->
                    <div class="purpose-section cta-section">
                        <h2>立即開始您的旅程</h2>
                        <p>選擇您喜愛的目的地，與我們一起計劃完美的旅行</p>
                        <a href="/productList" class="btn btn-primary">瀏覽商品</a>
                    </div>

                </div>
            </section>
        </div>
    </div>
</div>