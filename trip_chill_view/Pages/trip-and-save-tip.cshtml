@page
@model trip_chill_view.Pages.trip_and_save_tipModel
@{
}
<link rel="stylesheet" href="~/css/search-group.css">
<div class="Wrapper-hot-color">
    <div class="container">
        <div class="col-group-title-hot-01">
            <h3>簡介</h3>
            <!--<p>精選近3個月暢銷課程，緊跟潮流!</p>-->
        </div>
        <div>
            <hr>
        </div>
        <div class="intro-container">
            <!-- 簡介標題區 -->
            <section class="intro-hero">
                <div class="hero-content">
                    <h1>Trip Chill View</h1>
                    <p class="hero-subtitle">您的旅遊規劃好幫手</p>
                </div>
            </section>

            <!-- 簡介內容 -->
            <section class="intro-content">
                <div class="container">
                    <!-- 部分 1：關於我們 -->
                    <div class="intro-section">
                        <h2>關於我們</h2>
                        <p>
                            Trip Chill View 是一個創新的旅遊電商平台，致力於為每一位旅客提供最便捷、最實惠的出國體驗。
                            我們相信，旅遊不應該是複雜的，而是應該充滿期待和放鬆。
                        </p>
                        <p>
                            無論您是計劃一次商務旅行、家庭假期或冒險旅程，Trip Chill View 都能為您提供全方位的服務支持。
                        </p>
                    </div>

                    <!-- 部分 2：我們的使命 -->
                    <div class="intro-section">
                        <h2>我們的使命</h2>
                        <div class="mission-cards">
                            <div class="card">
                                <i class="fa fa-globe"></i>
                                <h3>簡化旅遊規劃</h3>
                                <p>一站式解決所有旅遊需求，讓您輕鬆規劃每一段旅程</p>
                            </div>
                            <div class="card">
                                <i class="fa fa-dollar"></i>
                                <h3>提供優惠價格</h3>
                                <p>與全球合作夥伴合作，為您爭取最優惠的價格和服務</p>
                            </div>
                            <div class="card">
                                <i class="fa fa-headphones"></i>
                                <h3>貼心客服支持</h3>
                                <p>24/7 客服團隊隨時準備好協助您解決任何問題</p>
                            </div>
                        </div>
                    </div>

                    <!-- 部分 3：我們的特色 -->
                    <div class="intro-section">
                        <h2>我們的特色</h2>
                        <ul class="features-list">
                            <li>
                                <strong>多樣化選擇：</strong>
                                從機票、飯店、到當地體驗，應有盡有
                            </li>
                            <li>
                                <strong>安全支付：</strong>
                                採用 ECPay 等安全支付系統，保護您的每一筆交易
                            </li>
                            <li>
                                <strong>即時確認：</strong>
                                下單後立即確認，無需等待
                            </li>
                            <li>
                                <strong>靈活退改：</strong>
                                提供靈活的退改政策，讓您無後顧之憂
                            </li>
                            <li>
                                <strong>在地知識：</strong>
                                我們的團隊精通各地文化和最佳旅遊時間，為您提供專業建議
                            </li>
                        </ul>
                    </div>

                    <!-- 部分 4：為什麼選擇我們 -->
                    <div class="intro-section">
                        <h2>為什麼選擇 Trip Chill View？</h2>
                        <div class="why-us">
                            <div class="why-item">
                                <div class="why-number">5000+</div>
                                <div class="why-text">滿意顧客</div>
                            </div>
                            <div class="why-item">
                                <div class="why-number">50+</div>
                                <div class="why-text">目的地選擇</div>
                            </div>
                            <div class="why-item">
                                <div class="why-number">99.5%</div>
                                <div class="why-text">支付成功率</div>
                            </div>
                            <div class="why-item">
                                <div class="why-number">24/7</div>
                                <div class="why-text">客服支持</div>
                            </div>
                        </div>
                    </div>

                    <!-- 部分 5：開始旅程 -->
                    <div class="intro-section cta-section">
                        <h2>準備好了嗎？</h2>
                        <p>立即瀏覽我們的優惠商品，開始您的下一段冒險！</p>
                        <a href="/productList" class="btn btn-primary btn-lg">探索商品</a>
                    </div>
                </div>
            </section>
        </div>

    </div>
</div>