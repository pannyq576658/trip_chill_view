                discoveryDocs: DISCOVERY_DOCS
            });
        });
    </script>
    <script>
        const enableLocalLogin = @Configuration["AppSettings:EnableLocalLoginMode"]?.ToLower() ?? "false";

        member = new member();
        loading = new loading();
        var route = '@Configuration["AppSettings:route"]';
        $(function () {
            if (loading.loadingTask == 0)
                loading.Startup();
            else
                loading.TaskAdd()

            LineInit('2002691476-KlYvJ5j8');
            $('.btnFBLogin').click(function () {
                doFBLoginTest();
            });

            $('.btnGGLogin').click(function () {
                doGGLogin();
            });

            $('.btnLineLogin').click(function () {
                doLineLogin();
            });

            $('#ctl00_ContentPlaceHolder1_btnSubmit').click(function () {
                doLogin();
            });

        });

        window.onload = function () {
            member.print();
            function loginStateView() {
                $('.navbar-cards .user-icon').attr('style', "background-image: url(" + member.picture + ");");
                $('.userSignin .user-icon').attr('style', "background-image: url(" + member.picture + ");");
                $('.navbar-cards .username').text(member.name);
                $('.userSignout').hide();
                $('.userSignin').show();
                $('.badge').text(member.cartNum);
                if (location.pathname == '/login' || location.pathname == '/register')
                    top.location.href = '/';
            }
            function logoutStateView() {
                $('.userSignin .user-icon').css('background-image', '');
                $('.userSignout').show();
                $('.userSignin').hide();
                $('.badge').text('');
                if (location.pathname.includes('/cart') || location.pathname == '/profile' || location.pathname == '/orders' || (location.pathname != '/productList' && location.pathname.includes('/productList/')))
                    top.location.href = '/login';
            }
            function FB_reload() {
                FB.getLoginStatus(function (res) {
                    if (res.status === "connected") {
                        loginStateView()
                    }
                });
            }
            if (member.platform == "google")
                loginStateView()
            else if (member.platform == "line")
                loginStateView()
            else if (member.platform == "fb") {
                FB.getLoginStatus(function (res) {
                    if (res.status === "connected")
                        loginStateView()
                    else {
                        console.log('重新載入fb');
                        setInterval(FB_reload, 3000);
                    }
                    /*else if (res.status === 'not_authorized' || res.status === "unknown") {
                        $('.userSignin .user-icon').css('background-image', '');
                        $('.userSignout').show();
                        $('.userSignin').hide();
                        if (location.pathname == '/cart' || location.pathname == '/profile' || location.pathname == '/orders')
                            top.location.href = '/login';
                    }*/

                });

            }
            else if (member.platform == 'tripView')
                loginStateView()
            else {
                logoutStateView()
            }

            if (location.pathname.includes('/cart')) {
                if (location.pathname == '/cart')
                    mainCartRun();
                else if (location.pathname.replace('/cart', '') == '/payCheckout')
                    mainCartPayRun();
            }

            if (location.pathname.includes('/productList')) {
                if (location.pathname == '/productList')
                    mainProductRun();
                else {
                    var parameter = location.pathname.replace('/productList/', '');
                    mainProductDetailRun(parameter);
                }
            }

            if (location.pathname.includes('/shoppingCart-return')) {
                var parameter = location.pathname.replace('/shoppingCart-return/', '');
                mainPayReturnRun(parameter)
                $.get(route + '/api/member/' + member.id).done(function (result, textStatus, jqXHR) {
                    member.setData(result.data)
                    loginStateView();
                });
            }

            if (location.pathname == '/orders')
                mainOrderRun();
            if (location.pathname == '/profile')
                mainProfileRun();
            if (location.pathname == '/productDetail')
                top.location.href = '/';
            /* if (location.pathname == '/' && member.platform != '') {

                 $.get('https://localhost:44374/api/member/' + member.id).done(function (data, textStatus, jqXHR) {
                     console.log(data)
                     member.setData(data);
                     loginStateView();
                 });
             }*/
            loading.TaskSub()
        }
    </script>
