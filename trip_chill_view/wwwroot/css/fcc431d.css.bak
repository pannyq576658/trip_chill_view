.transition-position{transition-property:top,left,right,bottom}
.transition-transform{transition-property:transform}
.transition-colors{transition-property:background-color,border-color,color,fill,stroke}
.transition-all{transition-property:all}
.transition-opacity{transition-property:opacity}
.transition-width{transition-property:width}
.transition-pm{transition-property:padding,margin,opacity,background-color,color}
.transition-max-height{transition-property:max-height}
.transition-height{transition-property:height}
.delay-300{transition-delay:.3s}
.duration-300{transition-duration:.3s}
.duration-100{transition-duration:.1s}
.duration-500{transition-duration:.5s}
.duration-200{transition-duration:.2s}
.duration-150{transition-duration:.15s}
.duration-\[0\.6s\]{transition-duration:.6s}
.ease-in{transition-timing-function:cubic-bezier(.4,0,1,1)}
.ease-in-out{transition-timing-function:cubic-bezier(.4,0,.2,1)}
.line-clamp-1{-webkit-line-clamp:1}
.line-clamp-1,.line-clamp-2{overflow:hidden;display:-webkit-box;-webkit-box-orient:vertical}
