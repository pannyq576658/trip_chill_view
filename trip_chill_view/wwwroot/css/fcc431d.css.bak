.card-layout-style{display:grid;grid-template-columns:repeat(1,minmax(0,1fr));gap:1.5rem}
@media (min-width:768px){
    .card-layout-style,.courses-layout,.ebook-layout,.packages-layout{grid-template-columns:repeat(2,minmax(0,1fr))}
}
@media (min-width:1024px){
    .courses-layout,.ebook-layout{-moz-column-gap:1rem;column-gap:1rem;row-gap:2rem}
    .card-layout-style,.packages-layout{gap:1rem}
    .card-layout-style,.courses-layout{grid-template-columns:repeat(4,minmax(0,1fr))}
    .ebook-layout{grid-template-columns:repeat(5,minmax(0,1fr))}}
