.shadow-lg{--tw-shadow:0 10px 15px -3px rgba(0,0,0,0.1),0 4px 6px -2px rgba(0,0,0,0.05)}
.shadow-blur,.shadow-lg{box-shadow:var(--tw-ring-offset-shadow,0 0 transparent),var(--tw-ring-shadow,0 0 transparent),var(--tw-shadow)}
.shadow-blur{--tw-shadow:0 10px 24px rgba(0,0,0,0.1)}
.shadow-aside{--tw-shadow:-5px 0 20px rgba(0,0,0,0.05)}
.shadow-aside,.shadow-sm{box-shadow:var(--tw-ring-offset-shadow,0 0 transparent),var(--tw-ring-shadow,0 0 transparent),var(--tw-shadow)}
.shadow-sm{--tw-shadow:0 1px 2px 0 rgba(0,0,0,0.05)}
.shadow-tab{--tw-shadow:0px 5px 15px rgba(0,0,0,0.05)}
.shadow-tab,.shadow-voucher{box-shadow:var(--tw-ring-offset-shadow,0 0 transparent),var(--tw-ring-shadow,0 0 transparent),var(--tw-shadow)}
.shadow-voucher{--tw-shadow:0px 2px 10px rgba(0,0,0,0.1)}
